{
  "name": "vue-cesium-vite-starter",
  "version": "0.0.1",
  "scripts": {
    "watch": "vue-tsc --watch",
    "dev": "vite --host",
    "build": "vite build",
    "build-with-check": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "clean": "bunx rimraf ./dist",
    "deploy-mah": "vite build --base=/apps/$npm_package_name/ && rsync -avz --delete dist/ mah@mah.priv.at:/var/www/static.mah.priv.at/apps/$npm_package_name/ && echo visit https://static.mah.priv.at/apps/$npm_package_name"
  },
  "dependencies": {
    "cesium": "^1.139.1",
    "echarts": "^6.0.0",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-qrcode": "^0.3.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vue": "^3.5.30",
    "vue-cesium": "^3.2.12"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-sfc": "^3.5.30",
    "eslint": "^10.0.3",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5"
  }
}
